{
  "name": "lokify",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "scripts": {
    "backup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\create-backup.ps1",
    "dev": "concurrently -n backend,frontend -c yellow,cyan \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm --prefix frontend run dev -- --port 3001",
    "dev:backend": "npm --prefix backend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "serve:frontend": "npm --prefix frontend run build && npm --prefix frontend run start -- --port 3001",
    "start:backend": "npm --prefix backend run start",
    "electron": "wait-on tcp:3001 tcp:4000 && electron ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^37.1.0",
    "wait-on": "^8.0.3"
  }
}

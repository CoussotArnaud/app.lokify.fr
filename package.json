{
  "name": "lokify",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "backup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\create-backup.ps1",
    "dev": "concurrently -n backend,frontend -c yellow,cyan \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace frontend -- --port 3001",
    "dev:backend": "npm run dev --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "serve:frontend": "npm run build --workspace frontend && npm run start --workspace frontend -- --port 3001",
    "start:backend": "npm run start --workspace backend",
    "electron": "wait-on tcp:3001 tcp:4000 && electron ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^37.1.0",
    "wait-on": "^8.0.3"
  }
}